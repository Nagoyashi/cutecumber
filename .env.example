# Copy to .env and fill in. The app refuses to start without a strong SECRET_KEY.
# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Where the SQLite database lives. Default: instance/cutecumber.db
# DATABASE=instance/cutecumber.db

# Where uploaded avatars are written. Default: instance/avatars. In prod this
# MUST be on persistent storage (the Fly volume) or photos vanish on redeploy.
# AVATAR_DIR=instance/avatars

# Used to build canonical URLs and OG tags. Set to https://cutecumber.cc in prod.
SITE_ORIGIN=http://localhost:5000

# Session cookie Secure flag. Default is ON (1). Set to 0 ONLY for local http dev.
COOKIE_SECURE=0

# Set to 1 ONLY when running behind a reverse proxy (Caddy/nginx) that sets
# X-Forwarded-For — otherwise rate limits key on the proxy's IP.
# TRUST_PROXY=1

# Search engines. Default 0 = robots.txt blocks everything (stealth).
# Flip to 1 on launch day.
# ROBOTS_ALLOW=1

# Password reset emails via Resend (https://resend.com). Without an API key,
# reset links are printed to the server console instead (dev mode).
# NOTE: the default resend.dev sender only delivers to YOUR OWN account email
# until cutecumber.cc is verified as a domain in the Resend dashboard.
# RESEND_API_KEY=re_...
# MAIL_FROM=cutecumber <hello@cutecumber.cc>
